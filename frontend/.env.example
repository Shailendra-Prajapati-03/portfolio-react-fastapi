# Base URL of the FastAPI backend (NO trailing slash).
# Local development:
VITE_API_BASE_URL=http://localhost:8000
# Production (set this in the Vercel dashboard, NOT in a committed file):
# VITE_API_BASE_URL=https://portfolio-api-xyko.onrender.com

# Formspree endpoint that delivers the contact-form email (HTTPS, works even
# where SMTP is blocked). Optional — defaults to the one baked into api.ts.
# VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/xyzkjvql
