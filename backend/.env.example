# --- App ---
APP_NAME=Portfolio API
ENVIRONMENT=development
DATABASE_URL=sqlite:///./portfolio.db

# Comma-separated list of allowed CORS origins (frontend URLs)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Email (optional) ---
# Leave SMTP_HOST empty to disable email sending; messages are still saved to DB.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@portfolio.dev
# Where contact notifications are delivered
CONTACT_RECEIVER=shailendraprajapati640@gmail.com
