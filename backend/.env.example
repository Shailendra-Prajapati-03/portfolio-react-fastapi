# --- App ---
APP_NAME=Portfolio API
# Set to "production" on Render so email failures surface as errors (not silent).
ENVIRONMENT=development
DATABASE_URL=sqlite:///./portfolio.db

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# In production add your Vercel domain, e.g.:
#   CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Regex for additional allowed origins (covers Vercel preview deployments).
# Defaults to all *.vercel.app; override or leave blank to disable.
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# --- Email: Option A — Resend (RECOMMENDED for Render/Vercel) ---
# HTTP API over port 443, so it works even where outbound SMTP is blocked
# (Render's free tier raises "Network is unreachable" for smtp.gmail.com).
# Sign up at resend.com, create an API key, set it here. If you haven't verified
# a domain, keep the default From and set CONTACT_RECEIVER to the email you used
# to sign up (Resend only delivers to that address until a domain is verified).
# When RESEND_API_KEY is set it takes priority over the SMTP settings below.
RESEND_API_KEY=
RESEND_FROM=Portfolio <onboarding@resend.dev>

# --- Email: Option B — Gmail SMTP (local dev / SMTP-friendly hosts) ---
# Leave SMTP_HOST empty to disable email; messages are still saved to the DB.
#
# The canonical names are below. For convenience these aliases also work:
#   SMTP_USER      also accepts  SMTP_USERNAME / EMAIL_HOST_USER / EMAIL_USER
#   SMTP_PASSWORD  also accepts  SMTP_PASS / EMAIL_HOST_PASSWORD / EMAIL_PASSWORD
#   SMTP_FROM      also accepts  EMAIL_FROM
#   CONTACT_RECEIVER also accepts EMAIL_TO / CONTACT_EMAIL
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
# Gmail App Password — 16 chars. Requires 2-Step Verification enabled on the
# account. Spaces are stripped automatically, but paste it without spaces.
SMTP_PASSWORD=xxxxxxxxxxxxxxxx
# From address — leave blank to reuse SMTP_USER (Gmail requires From = account).
SMTP_FROM=
# Where contact notifications are delivered.
CONTACT_RECEIVER=shailendraprajapati640@gmail.com
# Optional: set true to use implicit SSL. Port 465 also enables SSL automatically.
SMTP_USE_SSL=false
